# ── Foresight 환경 변수 예시 ──
# 로컬: cp .env.example .env  (백엔드 루트 .env 는 backend 가 읽음 — 아래 백엔드 항목은 프로젝트 루트 .env 권장)
#
# 배포 구성: 프론트 Vercel + API Azure for Students

# ═══════════════════════════════════════════════════════════
# Vercel (프론트) — 대시보드 Environment Variables
# ═══════════════════════════════════════════════════════════
# 권장(서버 layout에서 읽어 클라이언트에 전달 — NEXT_PUBLIC 미주입 시에도 동작):
# FORESIGHT_API_URL=https://<azure-api-fqdn>/api/v1
# 또는 (클라이언트 번들에 직접 박힘):
# NEXT_PUBLIC_API_URL=https://<azure-api-fqdn>/api/v1
# Production / Preview 각각 필요 시 설정 후 재배포

# ═══════════════════════════════════════════════════════════
# Azure Container Apps / App Service (백엔드만)
# ═══════════════════════════════════════════════════════════
# Vercel 프로덕션 origin 필수 (프로젝트마다 다름). 콤마 구분, 공백 없이.
# 예: https://my-app.vercel.app,http://localhost:3000
FORESIGHT_CORS_ORIGINS=

# ── Forum: PostgreSQL (async SQLAlchemy / asyncpg) ──
# 예: postgresql+asyncpg://user:password@host.postgres.database.azure.com:5432/foresight?ssl=require
DATABASE_URL=

# Alembic 마이그레이션용 동기 URL (비어 있으면 DATABASE_URL에서 +asyncpg 제거로 유도)
# DATABASE_URL_SYNC=postgresql://user:password@host:5432/foresight?sslmode=require

# NextAuth AUTH_SECRET 과 동일 값 — HS256 API JWT 검증 (BRIDGE_JWT_SECRET 미설정 시)
JWT_SECRET=
# 선택: Next /api/backend-jwt 전용 서명 키. 설정 시 프론트(BRIDGE_JWT_SECRET)·백엔드(BRIDGE_JWT_SECRET) 동일 값 필수.
# BRIDGE_JWT_SECRET=
# 백엔드 액세스 토큰 만료(분). 프론트 bridge TTL은 JWT_EXPIRE_MINUTES 또는 BRIDGE_JWT_EXPIRE_SECONDS와 맞출 것.
# JWT_EXPIRE_MINUTES=60

# ── Forum: Azure Blob (이미지 업로드) ──
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=forum-uploads
# 공개 읽기 컨테이너가 아니면 Blob SAS URL 생성 등 별도 정책 필요
AZURE_STORAGE_PUBLIC_BASE_URL=

LICHESS_API_TOKEN=
LICHESS_USER_AGENT=Foresight/1.0 (your-contact)
LICHESS_MAX_RETRIES=6

# ═══════════════════════════════════════════════════════════
# 로컬 Next.js (frontend/.env.local)
# ═══════════════════════════════════════════════════════════
# FORESIGHT_API_URL=http://localhost:8000/api/v1
# 또는 NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
#
# NextAuth (Auth.js) — Google + Discord
# AUTH_SECRET=   # openssl rand -base64 32
# AUTH_URL=http://localhost:3000
# AUTH_TRUST_HOST=true
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_DISCORD_ID=
# AUTH_DISCORD_SECRET=
# 백엔드 JWT와 반드시 동일 (issuer 포함):
# JWT_SECRET=
# JWT_ISSUER=foresight.local
#
# 회원가입 이메일 인증(SMTP). 비어 있으면 인증 단계 없이 닉네임·약관만으로 가입 완료 가능(로컬 편의).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# SMTP_USE_TLS=true
# Bridge TTL(초, 60~86400). 비우면 JWT_EXPIRE_MINUTES(기본 60)×60 초 사용.
# BRIDGE_JWT_EXPIRE_SECONDS=
# 로컬 frontend/.env.local 에도 동일 JWT_EXPIRE_MINUTES 권장 (bridgeJwt.ts)
# NextAuth 세션(쿠키) 수명 — API JWT와 별개:
# AUTH_SESSION_MAX_AGE_SECONDS=604800
# AUTH_SESSION_UPDATE_AGE_SECONDS=43200
