# ============================================================
# Foresight - 환경변수 템플릿
# 실제 값을 채운 후 .env 파일로 저장하세요 (.env는 .gitignore 처리됨)
# ============================================================

# Backend
BACKEND_URL=http://localhost:8000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Chess.com API (공개 API, 키 불필요 - 주석 참고용)
# https://www.chess.com/news/view/published-data-api

# Lichess API (OAuth 토큰, 선택 사항 - 공개 게임은 키 불필요)
LICHESS_API_TOKEN=
